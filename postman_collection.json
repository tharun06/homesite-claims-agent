{
  "info": {
    "name": "HomeSite Adjuster Dashboard API",
    "description": "Postman collection for local dashboard API. Uses mock login by email and stores the returned JWT in a collection variable for follow-up requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:8100",
      "type": "string"
    },
    {
      "key": "email",
      "value": "donaldgarcia@example.net",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "claimId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "vehicleVin",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "health"
          ]
        }
      },
      "response": []
    },
    {
      "name": "List login users",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/auth/users",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "users"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Login (mock email)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var json = pm.response.json();",
              "if (json.access_token) {",
              "  pm.collectionVariables.set('access_token', json.access_token);",
              "  console.log('Saved access token');",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/x-www-form-urlencoded"
          }
        ],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "email",
              "value": "{{email}}",
              "type": "text"
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Me (authenticated)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/me",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "me"
          ]
        }
      },
      "response": []
    },
    {
      "name": "List claims (authenticated)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var json = pm.response.json();",
              "if (json.claims && json.claims.length > 0) {",
              "  var first = json.claims[0];",
              "  pm.collectionVariables.set('claimId', first.id.toString());",
              "  if (first.vehicle && first.vehicle.vin) {",
              "    pm.collectionVariables.set('vehicleVin', first.vehicle.vin);",
              "  }",
              "  console.log('Saved claim id ' + first.id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/claims",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "claims"
          ]
        }
      },
      "response": []
    }
  ]
}
